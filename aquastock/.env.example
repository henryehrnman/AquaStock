# Supabase → Project Settings → API
# Copy this file to .env and paste your real Project URL and anon public key.
# Restart the dev server after any change (Vite loads env at startup).
# On Vercel: Settings → Environment Variables (same names, then redeploy).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
